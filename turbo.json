{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalPassThroughEnv": [
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "Z_API_KEY",
    "Z_API_BASE_URL",
    "RESEND_API_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_SECRET_KEY",
    "IRYS_UPLOAD_PRIVATE_KEY",
    "CRON_SECRET",
    "EXPO_ACCESS_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "STRIPE_SECRET_KEY_CARD",
        "STRIPE_WEBHOOK_SECRET_CARD",
        "SEED_TOKEN",
        "SUPABASE_SEED_TOKEN",
        "ADMIN_PASSWORD",
        "ADMIN_USERNAME",
        "SESSION_SECRET",
        "GNOSIS_BUNDLER_RPC_URL",
        "SAFE_API_KEY",
        "GNOSIS_RPC_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
