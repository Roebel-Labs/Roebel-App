# =============================================================
# Roebel/Müritz MACI v2 — Base Mainnet Deploy Environment
# =============================================================
# Copy this file to .env and fill in real values. .env is gitignored.
# Never paste a real private key in chat, in commits, or in screenshots.

# ---- Deployer wallet (the EOA that pays gas to deploy MACI infra) ----
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HEX
BASE_RPC_URL=https://mainnet.base.org
# Optional: a private RPC if you don't want to share traffic with the public one
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional: only needed if you want `npx hardhat verify` to push source to Basescan
BASESCAN_API_KEY=

# ---- Existing on-chain Roebel addresses (Base mainnet, rotated 2026-05-23) ----
ATTESTER_NFT_ADDRESS=0x79B837b269f3EB3FB1c5856fE1E21675F05a3aFb
CITIZEN_NFT_ADDRESS=0x7eF8308129C47E31415BEfC210aCEbD8ae6861BB

# ---- NFT initial owner ----
# Defaults to the deployer (burner) if unset — script then auto-transfers
# ownership to the new Timelock at the end of the deploy. Override only if a
# different EOA needs interim control (e.g. for a bulk-mint migration helper).
# NFT_INITIAL_OWNER=

# ---- Coordinator (the off-chain service that decrypts votes + posts the tally) ----
# This is a SEPARATE address from the deployer. Generate it on the Coordinator host
# and never expose its private key. The Governor records this address as the only
# party allowed to submit MessageProcessor / Tally proofs.
# v1: a single EOA. v1.1: a 3-of-5 Gnosis Safe of founding attesters.
COORDINATOR_ADDRESS=0x0000000000000000000000000000000000000000

# Coordinator's MACI Babyjubjub public key.
# Generate via:
#   pnpm dlx maci-cli generateMaciKeypair
# It prints a serialized macipk.<...> public key and private key.
# The deploy script reads these as decimal big integers (x, y point on BabyJubjub).
COORDINATOR_PUBKEY_X=0
COORDINATOR_PUBKEY_Y=0

# ---- Governance parameters ----
# Voting period in seconds (e.g. 604800 = 7 days). Must equal the MACI Poll duration.
VOTING_PERIOD_SECONDS=604800
# Quorum threshold: percentage of CitizenNFT total supply that must vote (0-100).
QUORUM_PERCENTAGE=10
# Grace window after voting deadline for the coordinator to publish the tally.
TALLY_GRACE_PERIOD_SECONDS=604800
# Timelock minimum delay in seconds before queued proposals can execute.
TIMELOCK_MIN_DELAY_SECONDS=172800

# ---- zKey artifacts (downloaded by `pnpm download:zkeys`) ----
# Default points at the production-ceremony non-QV tarball extracted in ./zkeys/
ZKEY_PROCESS_MESSAGES=./zkeys/ProcessMessagesNonQv_14-9-2-3/processmessagesnonqv_14-9-2-3.zkey
ZKEY_TALLY_VOTES=./zkeys/TallyVotesNonQv_14-5-3/tallyvotesnonqv_14-5-3.zkey
