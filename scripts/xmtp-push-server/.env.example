# Secrets for the Röbel XMTP push notification server (set via `fly secrets set`).
# Copy the values in from Apple + Firebase; do NOT commit real values.

# Postgres (fly postgres attach sets DATABASE_URL on the app; mirror it here so
# the server's -d flag resolves it).
DB_CONNECTION_STRING=postgres://user:pass@host:5432/dbname

# Apple Push Notification service (APNs) — from the Apple Developer portal:
#   Certificates, IDs & Profiles → Keys → new key with "Apple Push Notifications service (APNs)"
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YYYYYYYYYY
APNS_TOPIC=com.roebel.app          # the iOS bundle id (confirm in apps/expo/app.config.ts)
# Paste the FULL contents of the downloaded AuthKey_XXXXXXXXXX.p8 (multiline).
APNS_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Firebase Cloud Messaging (FCM) — same Firebase project as apps/expo/keys/google-services.json
FCM_PROJECT_ID=roebel-xxxxx
# The service-account JSON, single line (Firebase console → Project settings → Service accounts → Generate new private key)
FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"roebel-xxxxx", ...}
