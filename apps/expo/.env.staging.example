# =============================================================================
# apps/expo — STAGING env template
# =============================================================================
# For running the Expo app against the shared `roebel-staging` backend.
#
#   cp apps/expo/.env.staging.example apps/expo/.env
#
# NOTE: Expo env BAKES AT BUILD TIME (app.config.ts reads process.env into
# `extra`). So changing this file requires restarting the dev server (local /
# Expo Go) or a new `eas build --profile staging` (for a distributed dev build).
# It is NOT applied via OTA update. See docs/STAGING_ENVIRONMENT.md.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# MINIMAL SET — all a contributor needs to run the app locally (Expo Go).
# Ask the maintainer for the staging Supabase URL + anon key (both safe to share).
# -----------------------------------------------------------------------------

# Staging Supabase (NOT production)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key

# Thirdweb client id (public)
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Points the mini-app host + server-authorized Münzen/notification bridge at the
# staging web API. Use the hosted staging site so mobile talks to the same backend.
EXPO_PUBLIC_MINIAPP_API_BASE=https://staging.roebel.app

# Verification contract addresses — LIVE Gnosis v2 (chain 100), shared read-only.
# Leave these as the in-code defaults unless you know you need to override.
# NEXT_PUBLIC_ATTESTER_NFT=0xC587F383696D3c9DF7A6eE03A9160E40Ae1cdb82
# NEXT_PUBLIC_CITIZEN_NFT=0x59aA26f499D7C2B3EC2c8524Ed06F54fc4E85dE5

# =============================================================================
# OPTIONAL — leave BLANK for local contributor testing. Features that use these
# degrade gracefully (maps blank, no analytics, push is a no-op). Only the
# maintainer sets these for a distributed `eas build --profile staging` build.
# =============================================================================

# Thirdweb secret (server-side SDK usage only; not needed for normal app testing)
THIRDWEB_SECRET_KEY=

# Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# AI (in-app Mecky / assistants)
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=

# Evidence uploads (Irys) — generate a THROWAWAY key, never a real wallet:
#   node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
IRYS_UPLOAD_PRIVATE_KEY=

# Observability (leave blank on staging to avoid polluting prod analytics)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=

# XMTP push server — leave BLANK on staging (push registration becomes a no-op,
# so staging never sends notifications to real users).
EXPO_PUBLIC_XMTP_PUSH_SERVER=
