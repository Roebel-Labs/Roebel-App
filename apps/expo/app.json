{
  "expo": {
    "name": "roebel-onchain",
    "slug": "roebel-onchain",
    "version": "3.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "roebel",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maxbrych.roebelonchain",
      "buildNumber": "25",
      "associatedDomains": [
        "applinks:www.roebel.app"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby events and services.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to show nearby events and services.",
        "NSCameraUsageDescription": "This app uses the camera to upload photos.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photos to upload images.",
        "NSPhotoLibraryAddUsageDescription": "This app saves photos to your library.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.maxbrych.roebelonchain"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.maxbrych.roebelonchain",
      "versionCode": 32,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.roebel.app",
              "pathPrefix": "/r/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "android": false,
            "ios": false,
            "default": "development"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "extraPods": [
              {
                "name": "OpenSSL-Universal",
                "configurations": [
                  "Release",
                  "Debug"
                ],
                "modular_headers": true,
                "version": "3.3.2000"
              }
            ]
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cb460582-e228-4a96-8235-92eb13006239"
      }
    },
    "owner": "max.brych"
  }
}
