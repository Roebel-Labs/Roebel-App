# Thirdweb
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps API Key for Android (required for map functionality)
# Get your key from: https://console.cloud.google.com/google/maps-apis
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox (for map views)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# AI APIs
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key

# Verification System Contract Addresses (Base Mainnet)
NEXT_PUBLIC_ATTESTER_NFT=0xa06F09Cb406880512326318fbC09Cdb28631DA73
NEXT_PUBLIC_CITIZEN_NFT=0xe2d39ffd2ee0Ccd753486047AEBec031F334b5b7
NEXT_PUBLIC_GOVERNOR=0x84D8ab0FcA4D0689e2E3F036dc461942343c2a5b

# Legacy Contract Addresses
NEXT_PUBLIC_NFT_CONTRACT=0xc49003E2b834ee10CADa6bcf3b369C7b9E01d7cd
NEXT_PUBLIC_GOVERNOR_CONTRACT=0xBa4d0DD1a0e4bF8B08e8eF39FcaEA16F9CDDb90B

# Irys Upload Configuration (for evidence storage)
# Generate a new wallet for Irys uploads only (DO NOT use your main wallet)
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
IRYS_UPLOAD_PRIVATE_KEY=0x_your_irys_upload_private_key
