# Thirdweb
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps API Key for Android (required for map functionality)
# Get your key from: https://console.cloud.google.com/google/maps-apis
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox (for map views)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# AI APIs
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key

# Netizen Mini Apps — base URL of the apps/web API that backs the mini-app host
# (server-authorized Röbel-Münzen balance/rewards + notifications). Without it, those
# host bridge methods reply "unsupported" (wallet/haptics/share/context/track still work).
EXPO_PUBLIC_MINIAPP_API_BASE=https://your-web-app.vercel.app

# Verification System Contract Addresses (Gnosis v2 Sybil-hardened, chainId 100, 2026-06-25).
# Leave UNSET to use the in-code Gnosis v2 defaults (constants/thirdweb.ts). If set, these
# OVERRIDE the code — make sure they point at the v2 contracts, not Base.
NEXT_PUBLIC_ATTESTER_NFT=0xC587F383696D3c9DF7A6eE03A9160E40Ae1cdb82
NEXT_PUBLIC_CITIZEN_NFT=0x59aA26f499D7C2B3EC2c8524Ed06F54fc4E85dE5
NEXT_PUBLIC_GOVERNOR=0x140F0eC647E9eBF9AbD293A7976edBc7d8C2dB65

# Legacy Contract Addresses
NEXT_PUBLIC_NFT_CONTRACT=0xc49003E2b834ee10CADa6bcf3b369C7b9E01d7cd
NEXT_PUBLIC_GOVERNOR_CONTRACT=0xBa4d0DD1a0e4bF8B08e8eF39FcaEA16F9CDDb90B

# Irys Upload Configuration (for evidence storage)
# Generate a new wallet for Irys uploads only (DO NOT use your main wallet)
# Generate with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
IRYS_UPLOAD_PRIVATE_KEY=0x_your_irys_upload_private_key

# Observability (PostHog analytics, Sentry error tracking)
# PostHog: https://eu.posthog.com -> Project Settings -> Project API Key (phc_...)
EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Sentry: https://sentry.io -> Settings -> Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oxxx.ingest.de.sentry.io/xxx
