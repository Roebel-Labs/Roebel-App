# Public read-only Stadtstack origin. Leave empty to show the honest
# "not configured" state; never place credentials or private API URLs here.
NEXT_PUBLIC_STADTSTACK_PUBLIC_BASE_URL=

# Optional stakeholder walkthrough. The client accepts this only when the
# server body and truth headers all declare a non-authoritative synthetic demo.
NEXT_PUBLIC_STADTSTACK_DEMO_SCENARIO=

# Build a deliberately isolated, public staging page for the synthetic
# Marienfelder Straße walkthrough. This is not implied by the walkthrough flag
# above: leave it empty for the normal Röbel Mini App.
NEXT_PUBLIC_STADTSTACK_PUBLIC_DEMO_MODE=

# Optional pathname when this standalone app is served below a shared staging
# hostname, for example /roebel-data-demo. Never put a full URL here.
NEXT_PUBLIC_MINIAPP_BASE_PATH=
