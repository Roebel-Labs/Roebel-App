# Thirdweb Client ID (for blockchain connection)
NEXT_PUBLIC_TEMPLATE_CLIENT_ID=your_thirdweb_client_id

# Higher-cap ERC-4337 bundler for Gnosis, used ONLY for creating a governance
# proposal. propose() deploys a MACI Poll inline (~15.7M gas), which exceeds
# thirdweb's hosted bundler cap of 12M gas/bundle (this worked on Base because
# Base's bundler cap is higher). Fix: route proposal creation through a Gnosis
# bundler that allows up to the block-gas limit (~17M), e.g. Pimlico.
#
# Recommended (key stays server-side via the /api/bundler proxy):
#   NEXT_PUBLIC_GNOSIS_BUNDLER_URL=/api/bundler           (client → same-origin proxy)
#   GNOSIS_BUNDLER_RPC_URL=https://api.pimlico.io/v2/100/rpc?apikey=YOUR_PIMLICO_KEY  (server-only secret)
#
# proposal creation then self-pays gas from the proposer's (funded) attester
# smart account; every other tx keeps the default sponsored bundler. Leave both
# blank to disable (proposal creation will fail on the 12M cap).
NEXT_PUBLIC_GNOSIS_BUNDLER_URL=/api/bundler
GNOSIS_BUNDLER_RPC_URL=

# Google Maps API Key (for location geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI API Key (for AI-powered event submission)
OPENAI_API_KEY=your_openai_api_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mecky Bot - AI News Generation (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Netizen AI mini-app builder codegen — Z.ai GLM-5.2 via the official z.ai API.
# Default endpoint is the GLM Coding Plan one (https://api.z.ai/api/coding/paas/v4);
# pay-as-you-go keys should set Z_API_BASE_URL=https://api.z.ai/api/paas/v4
Z_API_KEY=your_zai_api_key
# Z_API_BASE_URL=https://api.z.ai/api/paas/v4

# Netizen Mini Apps — optional origin override for the /mini/<slug> home URLs the
# AI builder publishes (defaults to the request origin of the publish call).
# MINI_APPS_WEB_ORIGIN=https://roebel.app

# Legacy: base URL for externally-hosted (multi-file) mini apps registered manually.
MINI_APPS_BASE_URL=https://mini.roebel.app

# Vercel Cron Secret (protects /api/cron/* endpoints)
CRON_SECRET=your_cron_secret

# Shared secret for the generate-menu-image Supabase Edge Function (kie.ai AI image gen).
# Must match the SEED_TOKEN env var set on the Supabase project. Server-only — do NOT prefix with NEXT_PUBLIC_.
# NOTE: this same value must ALSO be set in the deployment host (e.g. Vercel) env vars,
# otherwise the dashboard shows "AI-Bilderzeugung ist aktuell nicht konfiguriert (SEED_TOKEN fehlt)".
SUPABASE_SEED_TOKEN=your_seed_token

# AI image generation requires TWO secrets on the Supabase project itself
# (Dashboard → Edge Functions → Secrets), NOT in this web env file:
#   SEED_TOKEN   = the exact same value as SUPABASE_SEED_TOKEN above (the edge function compares them)
#   KIE_API_KEY  = an API key from a kie.ai account (Seedream 4.5 text-to-image + 4.5-edit)

# Mini-App icon & store-preview generation (Nano Banana 2 via kie.ai, called
# directly from /api/mini-apps/images*). Same kie.ai account as above works.
# Without it, image generation returns 503 "Bildgenerierung ist nicht konfiguriert".
KIE_API_KEY=your_kie_api_key

# Admin dashboard login (apps/web → /admin/login).
# These gate /admin/dashboard. NEVER commit real values — set them in the
# deployment environment (e.g. Vercel project env). SESSION_SECRET signs the
# session cookie and must be a long random string (>= 16 chars).
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
SESSION_SECRET=replace-with-a-long-random-secret

# Safe Transaction Service API key (server-only) for the Gemeinschaftskasse page
SAFE_API_KEY=your-safe-api-key

# Dev-Ticket-Board — GitHub-Integration (Fix-Dispatch, PR-Status, Merge)
# Fine-grained PAT: Actions RW + Contents RW + Pull requests RW auf das Repo
GITHUB_TICKETS_TOKEN=github_pat_xxx
GITHUB_TICKETS_REPO=Roebel-Labs/Roebel-App

# Newsletter (Resend webhook signing secret — Resend Dashboard → Webhooks)
RESEND_WEBHOOK_SECRET=whsec_placeholder
# Optional: where "Entwurf bereit" notifications go (default: support@roebel.app)
NEWSLETTER_ADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Gemeinschaftskasse contributions (Unterstützen / donations)
# ---------------------------------------------------------------------------
# Monerium webhook subscription signing secret (created when POSTing
# /webhooks to api.monerium.app — base64 random 24-64 bytes, whsec_ prefix).
MONERIUM_WEBHOOK_SECRET=whsec_placeholder
# Dedicated Stripe webhook endpoint secret for /api/donate/webhook
# (falls back to STRIPE_WEBHOOK_SECRET when unset).
STRIPE_WEBHOOK_SECRET_DONATIONS=whsec_placeholder
# Fallbacks for the app_settings keys donation_iban / donation_bic /
# donation_recipient_name (app_settings wins when set).
DONATION_IBAN=
DONATION_BIC=
DONATION_RECIPIENT_NAME=
