# Thirdweb Client ID (for blockchain connection)
NEXT_PUBLIC_TEMPLATE_CLIENT_ID=your_thirdweb_client_id

# Higher-cap ERC-4337 bundler for Gnosis, used ONLY for creating a governance
# proposal. propose() deploys a MACI Poll inline (~15.7M gas), which exceeds
# thirdweb's hosted bundler cap of 12M gas/bundle. Point this at a Gnosis bundler
# that allows up to the block-gas limit (~17M), e.g. Pimlico:
#   https://api.pimlico.io/v2/100/rpc?apikey=YOUR_PIMLICO_KEY
# When set, proposal creation self-pays gas from the proposer's (funded) attester
# smart account through this bundler. Every other tx keeps the default sponsored
# bundler. Leave blank to disable (proposal creation will fail on the 12M cap).
NEXT_PUBLIC_GNOSIS_BUNDLER_URL=

# Google Maps API Key (for location geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI API Key (for AI-powered event submission)
OPENAI_API_KEY=your_openai_api_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Mecky Bot - AI News Generation (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Vercel Cron Secret (protects /api/cron/* endpoints)
CRON_SECRET=your_cron_secret

# Shared secret for the generate-menu-image Supabase Edge Function (kie.ai AI image gen).
# Must match the SEED_TOKEN env var set on the Supabase project. Server-only — do NOT prefix with NEXT_PUBLIC_.
# NOTE: this same value must ALSO be set in the deployment host (e.g. Vercel) env vars,
# otherwise the dashboard shows "AI-Bilderzeugung ist aktuell nicht konfiguriert (SEED_TOKEN fehlt)".
SUPABASE_SEED_TOKEN=your_seed_token

# AI image generation requires TWO secrets on the Supabase project itself
# (Dashboard → Edge Functions → Secrets), NOT in this web env file:
#   SEED_TOKEN   = the exact same value as SUPABASE_SEED_TOKEN above (the edge function compares them)
#   KIE_API_KEY  = an API key from a kie.ai account (Seedream 4.5 text-to-image + 4.5-edit)

# Admin dashboard login (apps/web → /admin/login).
# These gate /admin/dashboard. NEVER commit real values — set them in the
# deployment environment (e.g. Vercel project env). SESSION_SECRET signs the
# session cookie and must be a long random string (>= 16 chars).
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
SESSION_SECRET=replace-with-a-long-random-secret
