# =============================================================================
# apps/web — STAGING env template
# =============================================================================
# For running apps/web LOCALLY against the shared `roebel-staging` backend.
#
#   cp apps/web/.env.staging.example apps/web/.env.local
#
# See docs/FORKING_GUIDE.md (contributors) and docs/STAGING_ENVIRONMENT.md
# (maintainer runbook). The hosted staging site lives at https://staging.roebel.app
# and already has every server secret — you only need this file to run locally.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# MINIMAL SET — this is ALL a contributor needs to run the web app locally.
# Ask the maintainer for the staging Supabase URL + anon key. Both are SAFE to
# share (the anon key is RLS-gated and already ships inside the published app).
# -----------------------------------------------------------------------------

# Staging Supabase (NOT production — points at the roebel-staging project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key

# Thirdweb client id (public). A public/staging client id is fine; ask the
# maintainer, or create a free one at https://thirdweb.com/dashboard.
NEXT_PUBLIC_TEMPLATE_CLIENT_ID=your_thirdweb_client_id

# Gnosis bundler proxy — leave as-is. Blockchain is the LIVE Gnosis mainnet
# (chain 100), shared read-only. You do NOT need the server-side Pimlico key
# to browse/test; it's only required to actually CREATE a governance proposal,
# which needs an Attester NFT you won't hold on staging anyway.
NEXT_PUBLIC_GNOSIS_BUNDLER_URL=/api/bundler
GNOSIS_BUNDLER_RPC_URL=

# =============================================================================
# EVERYTHING BELOW IS MAINTAINER-ONLY (server secrets).
# Leave BLANK for local contributor testing — the affected server routes simply
# no-op or degrade gracefully, and none of the read-heavy app UX depends on them.
# These are set by the maintainer ONLY on the hosted staging Vercel project.
#
# IMPORTANT (staging safety): the maintainer deliberately WITHHOLDS the cron /
# coordinator / webhook secrets on the staging Vercel project so those jobs
# no-op there and can never touch the real DAO or notify real users. See
# docs/STAGING_ENVIRONMENT.md → "Staging safety".
# =============================================================================

# Supabase service role (server-only, NEVER share, NEVER commit)
SUPABASE_SERVICE_ROLE_KEY=

# AI keys (Mecky news, event submission, mini-app codegen)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
Z_API_KEY=
# Z_API_BASE_URL=https://api.z.ai/api/paas/v4

# Maps / geocoding
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Mini apps
# MINI_APPS_WEB_ORIGIN=https://staging.roebel.app
MINI_APPS_BASE_URL=https://mini.roebel.app
KIE_API_KEY=
SUPABASE_SEED_TOKEN=

# Admin dashboard login (gates /admin/dashboard). Set your own for staging.
ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=

# Safe Transaction Service (Gemeinschaftskasse dashboard)
SAFE_API_KEY=

# --- WITHHOLD ON STAGING so crons/coordinator/webhooks stay inert ------------
# Leaving these blank is INTENTIONAL — it is how staging avoids double-running
# the coordinator against live contracts and avoids emailing/pushing real users.
CRON_SECRET=
GITHUB_TICKETS_TOKEN=
GITHUB_TICKETS_REPO=Roebel-Labs/Roebel-App
RESEND_WEBHOOK_SECRET=
NEWSLETTER_ADMIN_EMAIL=
MONERIUM_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_DONATIONS=
DONATION_IBAN=
DONATION_BIC=
DONATION_RECIPIENT_NAME=
